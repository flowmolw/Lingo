<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Lingo — 12 языков | 300 уровней | Алфавит каждого языка</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: system-ui, 'Segoe UI', 'Poppins', 'Inter', -apple-system, BlinkMacSystemFont, 'Roboto', sans-serif;
        }

        body {
            background: linear-gradient(145deg, #eef5e9 0%, #ddecd3 100%);
            min-height: 100vh;
            padding: 0.8rem;
        }

        .app-container {
            max-width: 1600px;
            margin: 0 auto;
        }

        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-card {
            background: white;
            border-radius: 2rem;
            padding: 2rem;
            max-width: 450px;
            width: 90%;
            text-align: center;
            animation: fadeInUp 0.3s ease;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .modal-card h2 { font-size: 1.8rem; background: linear-gradient(135deg, #1e3c2c, #3b7b4b); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .modal-card input { width: 100%; padding: 0.8rem; margin: 0.6rem 0; border: 2px solid #e2dacf; border-radius: 2rem; font-size: 1rem; outline: none; }
        .modal-card input:focus { border-color: #3b8b4e; }
        .modal-btn { background: #3b8b4e; color: white; border: none; padding: 0.8rem 1.5rem; border-radius: 2rem; font-weight: bold; cursor: pointer; margin: 0.5rem; width: calc(50% - 1rem); }
        .modal-btn.secondary { background: #ffb347; }
        .error-msg { color: #e74c3c; font-size: 0.8rem; }

        .alphabet-modal { max-width: 850px; width: 95%; max-height: 85vh; overflow-y: auto; }
        .alphabet-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 0.7rem; margin-top: 1rem; }
        .alphabet-card { background: #f9f7f3; border-radius: 1rem; padding: 0.7rem; text-align: center; border: 1px solid #e2dacf; }
        .alphabet-letter { font-size: 2rem; font-weight: 700; }
        .alphabet-pron { font-size: 0.8rem; color: #666; font-family: monospace; }
        .alphabet-example { font-size: 0.7rem; color: #3b8b4e; margin-top: 0.2rem; }

        .onboarding-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 900;
            display: none;
            align-items: center;
            justify-content: center;
        }

        .onboarding-card {
            background: white;
            border-radius: 2rem;
            padding: 1.5rem;
            max-width: 700px;
            width: 90%;
            max-height: 85vh;
            overflow-y: auto;
        }

        .lang-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 0.6rem; margin: 1rem 0; }
        .lang-option { background: #f0f0f0; border: 2px solid #ddd; padding: 0.6rem; border-radius: 1rem; cursor: pointer; text-align: center; font-weight: 500; }
        .lang-option.selected { background: #3b8b4e; border-color: #2f6e3f; color: white; }
        .level-option { background: #f9f7f3; border: 2px solid #e2dacf; padding: 0.8rem; border-radius: 1.5rem; cursor: pointer; margin-bottom: 0.6rem; display: flex; align-items: center; gap: 1rem; }
        .level-option.selected { background: #e0f0e3; border-color: #3b8b4e; }
        .start-btn { background: #ffb347; border: none; padding: 0.8rem; border-radius: 2rem; font-weight: bold; font-size: 1rem; cursor: pointer; width: 100%; margin-top: 1rem; }

        .main-interface { display: none; }
        .header { background: rgba(255,255,248,0.97); backdrop-filter: blur(10px); border-radius: 1.5rem; padding: 0.5rem 1.2rem; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; margin-bottom: 1rem; position: sticky; top: 0; z-index: 30; }
        .logo { display: flex; align-items: center; gap: 0.5rem; }
        .logo-icon { font-size: 1.6rem; background: #1e3c2c; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 30px; color: #ffd966; }
        .logo h1 { font-size: 1.3rem; background: linear-gradient(135deg, #1e3c2c, #3b7b4b); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .stats { display: flex; gap: 0.8rem; background: #fef9e6; padding: 0.3rem 1rem; border-radius: 50px; }
        .stat { display: flex; align-items: center; gap: 0.3rem; font-weight: 600; color: #2c5a2e; font-size: 0.8rem; }
        .user-info { display: flex; align-items: center; gap: 0.8rem; }
        .user-name { background: #3b8b4e; color: white; padding: 0.3rem 0.8rem; border-radius: 2rem; font-size: 0.8rem; }
        .alphabet-btn { background: #6c5ce7; color: white; border: none; padding: 0.3rem 0.8rem; border-radius: 2rem; cursor: pointer; font-size: 0.75rem; }
        .logout-btn { background: #e74c3c; color: white; border: none; padding: 0.3rem 0.8rem; border-radius: 2rem; cursor: pointer; font-size: 0.7rem; }

        .main-grid { display: grid; grid-template-columns: 360px 1fr; gap: 1rem; }
        .levels-panel { background: rgba(255,255,250,0.94); border-radius: 1.5rem; padding: 1rem; height: 70vh; display: flex; flex-direction: column; }
        .level-list-scroll { flex: 1; overflow-y: auto; }
        .level-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(75px, 1fr)); gap: 0.5rem; }
        .level-btn { background: white; border: 1px solid #e2d9ca; padding: 0.4rem 0.2rem; border-radius: 1rem; text-align: center; font-weight: 600; font-size: 0.7rem; cursor: pointer; }
        .level-btn.active { background: #3b8b4e; color: white; transform: scale(1.02); }
        .level-btn.completed { background: #c8e6d9; color: #1a472a; border-color: #7fae7a; }
        .level-btn.locked { opacity: 0.5; cursor: not-allowed; background: #ede7db; }

        .lesson-area { background: white; border-radius: 1.5rem; padding: 1.2rem; }
        .lesson-header { border-bottom: 2px solid #e9e0d2; padding-bottom: 0.5rem; margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center; }
        .level-description { background: #eef3ea; border-radius: 1rem; padding: 0.6rem 1rem; margin-bottom: 1rem; font-size: 0.85rem; border-left: 4px solid #3b8b4e; }
        .question-card { background: #fefcf7; border-radius: 1.3rem; padding: 1.2rem; margin: 0.6rem 0; text-align: center; }
        .question-text { font-size: 1.3rem; font-weight: 600; margin-bottom: 1rem; color: #2c3e2b; }
        .options { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; margin: 0.8rem 0; }
        .option-btn { background: white; border: 2px solid #e2dacf; padding: 0.5rem 1.2rem; border-radius: 2rem; font-size: 0.85rem; cursor: pointer; }
        .option-btn:hover:not(:disabled) { background: #eef3e6; border-color: #93ba7c; }
        .voice-btn { background: #6c5ce7; color: white; border: none; padding: 0.7rem 1.2rem; border-radius: 2rem; font-size: 0.9rem; cursor: pointer; display: inline-flex; align-items: center; gap: 0.5rem; }
        .voice-btn.listening { background: #e74c3c; animation: pulse 1s infinite; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
        .feedback { margin-top: 0.6rem; padding: 0.5rem; border-radius: 1rem; }
        .next-btn { background: #ffb347; border: none; padding: 0.5rem 1.5rem; font-weight: bold; border-radius: 2rem; cursor: pointer; margin-top: 0.5rem; }
        .congrats { background: #d9f0dd; border-radius: 1rem; padding: 0.8rem; text-align: center; margin: 0.6rem 0; font-weight: 600; }

        @media (max-width: 850px) { .main-grid { grid-template-columns: 1fr; } .question-text { font-size: 1.1rem; } }
    </style>
</head>
<body>
<div class="app-container">
    <div id="authModal" class="modal-overlay" style="display: flex;">
        <div class="modal-card">
            <div class="logo-icon" style="margin: 0 auto 0.5rem; width: 50px; height: 50px; font-size: 1.5rem;">🦜</div>
            <h2>Lingo</h2>
            <p>Войдите или зарегистрируйтесь</p>
            <input type="text" id="authUsername" placeholder="Имя пользователя" autocomplete="off">
            <input type="password" id="authPassword" placeholder="Пароль">
            <div id="authError" class="error-msg"></div>
            <div><button id="loginBtn" class="modal-btn">Войти</button><button id="registerBtn" class="modal-btn secondary">Регистрация</button></div>
        </div>
    </div>

    <div id="alphabetModal" class="modal-overlay" style="display: none; z-index: 1100;">
        <div class="modal-card alphabet-modal">
            <h2>🔤 Алфавит</h2>
            <p id="alphabetLangName" style="font-weight: bold;"></p>
            <div id="alphabetContent" class="alphabet-grid"></div>
            <button id="closeAlphabetBtn" class="modal-btn secondary" style="width: auto; margin-top: 1rem;">Закрыть</button>
        </div>
    </div>

    <div id="onboardingOverlay" class="onboarding-overlay">
        <div class="onboarding-card">
            <div class="logo-icon" style="margin: 0 auto 0.5rem; width: 50px; height: 50px; font-size: 1.5rem;">🦜</div>
            <h2>Выберите язык и уровень</h2>
            <div class="lang-grid" id="languageGrid"></div>
            <div id="levelSelectBlock">
                <div data-level="beginner" class="level-option"><div style="font-size:1.5rem;">🌱</div><div><h4>Я не знаю этот язык</h4><p>Начинаю с нуля, алфавит и основы</p></div></div>
                <div data-level="intermediate" class="level-option"><div style="font-size:1.5rem;">📚</div><div><h4>Я чуть-чуть знаю</h4><p>Базовые слова и фразы, нужна практика</p></div></div>
                <div data-level="advanced" class="level-option"><div style="font-size:1.5rem;">🎓</div><div><h4>Я знаю язык</h4><p>Хороший уровень, хочу прокачаться</p></div></div>
            </div>
            <button id="confirmLanguageBtn" class="start-btn">🚀 Начать обучение</button>
        </div>
    </div>

    <div id="mainInterface" class="main-interface">
        <div class="header">
            <div class="logo"><div class="logo-icon">🦜</div><h1>Lingo <span id="currentLangDisplay">English</span></h1></div>
            <div class="stats"><div class="stat">🏆 <span id="totalScore">0</span> XP</div><div class="stat">📘 <span id="completedLevelsCount">0</span>/300</div><div class="stat">🔥 <span id="streakDay">1</span></div></div>
            <div class="user-info"><button id="alphabetButton" class="alphabet-btn">🔤 Алфавит</button><span class="user-name" id="userNameDisplay"></span><button id="logoutMainBtn" class="logout-btn">🚪 Выйти</button></div>
        </div>
        <div class="main-grid">
            <aside class="levels-panel"><h3>🗺️ 300 уровней</h3><div class="level-list-scroll"><div id="levelListContainer" class="level-list"></div></div><button id="resetProgressBtn" style="margin-top:0.5rem; background:#f1e7db; border:none; padding:0.3rem; border-radius:1.5rem; cursor:pointer;">🔄 Сбросить прогресс языка</button><button id="changeLanguageBtn" style="margin-top:0.5rem; background:#e8dfd0; border:none; padding:0.3rem; border-radius:1.5rem; cursor:pointer;">🌍 Сменить язык</button></aside>
            <main class="lesson-area"><div class="lesson-header"><h2 id="levelTitle">Уровень 1</h2><div id="questionProgress">Вопрос 1/5</div></div><div id="levelDescriptionBlock" class="level-description"></div><div id="dynamicContent"></div></main>
        </div>
    </div>
</div>

