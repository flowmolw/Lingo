    let currentUser = null;
    let usersDB = {};

    function loadUsersDB() { const saved = localStorage.getItem("lingo_users_db"); if(saved) usersDB = JSON.parse(saved); else usersDB = {}; }
    function saveUsersDB() { localStorage.setItem("lingo_users_db", JSON.stringify(usersDB)); }

    function generateQuestionsForLevel(levelId, languageCode, skillLevel) {
        const lang = languagesList.find(l => l.code === languageCode);
        const isAdvanced = skillLevel === 'advanced';
        const topics = ["Приветствия","Семья","Еда","Цвета","Животные","Числа","Время","Погода","Путешествия","Работа","Школа","Спорт","Искусство","Технологии","Природа"];
        const topic = topics[levelId % topics.length];
        return [
            { type: 'translate', question: `Как перевести фразу "${lang.helloText}" на русский?`, options: ["Привет! Как дела?", "До свидания!", "Спасибо!", "Доброе утро!"], correct: "Привет! Как дела?", explanation: `"${lang.helloText}" — приветствие` },
            { type: 'translate', question: `Как перевести "I love learning" на русский?`, options: ["Я люблю учиться", "Я ненавижу учёбу", "Я учу английский", "Я хочу спать"], correct: "Я люблю учиться", explanation: "I love learning = Я люблю учиться" },
            { type: 'word', question: `Что означает "${lang.greeting}"?`, options: ["Привет", "Пока", "Спасибо", "Пожалуйста"], correct: "Привет", explanation: `"${lang.greeting}" — приветствие на ${lang.name}` },
            { type: 'voice', question: `🎤 Произнесите: "${isAdvanced ? `Фраза на ${lang.name}: ${lang.helloText}` : 'I love learning'}"`, targetPhrase: (isAdvanced ? lang.helloText.toLowerCase() : 'i love learning'), explanation: "Потренируйте произношение" },
            { type: 'translate', question: `Как сказать "Спасибо" на ${lang.name}?`, options: lang.code==='english'?["Thank you","Please","Sorry","Hello"]:lang.code==='spanish'?["Gracias","Por favor","Lo siento","Hola"]:["Спасибо","Пожалуйста","Извините","Привет"], correct: lang.code==='english'?"Thank you":lang.code==='spanish'?"Gracias":"Спасибо", explanation: `Вежливое слово "спасибо" на ${lang.name}` }
        ];
    }

    function initUserLevelsForLanguage(user, languageCode, skillLevel) {
        if(!user.progress[languageCode]) {
            const levels = [];
            const topics = ["Приветствия","Семья","Еда","Цвета","Животные","Числа","Время","Погода","Путешествия","Работа","Школа","Спорт","Искусство","Технологии","Природа","Здоровье","Одежда","Транспорт","Развлечения","Праздники"];
            for(let i=0; i<300; i++) {
                const topic = topics[i % topics.length];
                levels.push({
                    id: i, name: `Уровень ${i+1}: ${topic} ${Math.floor(i/20)+1 > 1 ? `(ч.${Math.floor(i/20)+1})` : ''}`,
                    description: skillLevel === 'beginner' ? "📖 Базовый уровень: учим простые слова и фразы" : (skillLevel === 'intermediate' ? "📚 Средний уровень: грамматика и диалоги" : "🎓 Продвинутый уровень: сложные конструкции"),
                    questions: generateQuestionsForLevel(i, languageCode, skillLevel)
                });
            }
            user.progress[languageCode] = { skillLevel, levelsData: levels, completedLevels: [], currentLevel: 0, levelScores: {}, lessonProgress: {}, totalPoints: 0 };
            user.progress[languageCode].lessonProgress[0] = { qIdx: 0, answers: [false, false, false, false, false] };
        }
    }

    function saveCurrentProgress() { if(currentUser && currentUser.activeLanguage) { usersDB[currentUser.username] = currentUser; saveUsersDB(); } }
    
    function renderLevelList() {
        if(!currentUser || !currentUser.activeLanguage) return;
        const prog = currentUser.progress[currentUser.activeLanguage];
        if(!prog) return;
        const container = document.getElementById("levelListContainer");
        container.innerHTML = "";
        for(let i=0; i<300; i++) {
            const unlocked = i===0 || prog.completedLevels.includes(i-1);
            const completed = prog.completedLevels.includes(i);
            const btn = document.createElement("button");
            btn.className = `level-btn ${prog.currentLevel===i?'active':''} ${completed?'completed':''} ${!unlocked && !completed?'locked':''}`;
            btn.innerHTML = `<div style="font-weight:800;">${i+1}</div><div style="font-size:0.55rem;">${prog.levelsData[i].name.substring(0,12)}</div>${completed?'✓':''}`;
            if(unlocked || completed) btn.onclick = () => { prog.currentLevel=i; if(!prog.lessonProgress[i]) prog.lessonProgress[i]={qIdx:0,answers:[false,false,false,false,false]}; saveCurrentProgress(); renderLevelList(); renderCurrentLesson(); updateStats(); };
            container.appendChild(btn);
        }
        document.getElementById("completedLevelsCount").innerText = prog.completedLevels.length;
    }

    function updateStats() {
        if(!currentUser || !currentUser.activeLanguage) return;
        const prog = currentUser.progress[currentUser.activeLanguage];
        if(prog) { document.getElementById("totalScore").innerText = prog.totalPoints; document.getElementById("completedLevelsCount").innerText = prog.completedLevels.length; document.getElementById("streakDay").innerText = Math.min(99, Math.floor(prog.totalPoints/100)+1); }
    }

    function renderCurrentLesson() {
        if(!currentUser || !currentUser.activeLanguage) return;
        const prog = currentUser.progress[currentUser.activeLanguage];
        const level = prog.levelsData[prog.currentLevel];
        document.getElementById("levelTitle").innerHTML = `📖 ${level.name}`;
        document.getElementById("levelDescriptionBlock").innerHTML = level.description;
        const lesson = prog.lessonProgress[prog.currentLevel];
        if(!lesson) { prog.lessonProgress[prog.currentLevel]={qIdx:0,answers:[false,false,false,false,false]}; saveCurrentProgress(); renderCurrentLesson(); return; }
        const qIdx = lesson.qIdx;
        document.getElementById("questionProgress").innerHTML = `Вопрос ${qIdx+1}/5`;
        const allDone = lesson.answers.every(v=>v===true);
        
        if(allDone && !prog.completedLevels.includes(prog.currentLevel)) {
            document.getElementById("dynamicContent").innerHTML = `<div class="congrats">🎉 Поздравляю! Уровень пройден! +50 очков 🎉</div><button class="next-btn" id="nextLvlBtn">➡️ Следующий уровень</button>`;
            document.getElementById("nextLvlBtn")?.addEventListener("click",()=>{
                if(!prog.completedLevels.includes(prog.currentLevel)){ prog.completedLevels.push(prog.currentLevel); prog.totalPoints+=50; prog.levelScores[prog.currentLevel]=(prog.levelScores[prog.currentLevel]||0)+50; }
                let nxt=prog.currentLevel+1;
                if(nxt<300){ prog.currentLevel=nxt; if(!prog.lessonProgress[nxt]) prog.lessonProgress[nxt]={qIdx:0,answers:[false,false,false,false,false]}; saveCurrentProgress(); renderLevelList(); renderCurrentLesson(); }
                else alert("🏆 ВЫ ПРОШЛИ ВСЕ 300 УРОВНЕЙ! Вы — настоящий полиглот! 🏆");
                updateStats(); saveCurrentProgress();
            });
            return;
        }
        
        if(lesson.answers[qIdx]){ document.getElementById("dynamicContent").innerHTML = `<div class="question-card"><button class="next-btn" id="gotoNext">➡️ Далее</button></div>`; document.getElementById("gotoNext")?.addEventListener("click",()=>goNext()); return; }
        
        const q = level.questions[qIdx];
        if(q.type === 'voice'){
            const voiceHTML = `<div class="question-card"><div class="question-text">${q.question}</div><button id="voiceRecordBtn" class="voice-btn">🎤 Нажми и произнеси</button><div id="voiceResult" class="feedback"></div><button id="voiceCheckBtn" class="next-btn" style="display:none;">✅ Проверить</button></div>`;
            document.getElementById("dynamicContent").innerHTML = voiceHTML;
            const recordBtn = document.getElementById("voiceRecordBtn");
            const resultDiv = document.getElementById("voiceResult");
            const checkBtn = document.getElementById("voiceCheckBtn");
            let recordedText = "";
            if('webkitSpeechRecognition' in window || 'SpeechRecognition' in window){
                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                const recognition = new SpeechRecognition();
                recognition.lang = 'en-US';
                let listening=false;
                recordBtn.onclick = () => { if(listening) return; listening=true; recordBtn.classList.add("listening"); recordBtn.innerHTML="🎙️ Слушаю..."; recognition.start();
                recognition.onresult = (event) => { recordedText = event.results[0][0].transcript.toLowerCase().trim(); resultDiv.innerHTML = `🎤 Вы сказали: "${recordedText}"`; resultDiv.style.background="#e8f0fe"; checkBtn.style.display="inline-block"; recordBtn.classList.remove("listening"); recordBtn.innerHTML="🎤 Нажми и произнеси"; listening=false; };
                recognition.onerror = () => { recordBtn.classList.remove("listening"); recordBtn.innerHTML="🎤 Ошибка"; listening=false; };
                recognition.onend = () => { if(listening){ recordBtn.classList.remove("listening"); recordBtn.innerHTML="🎤 Нажми и произнеси"; listening=false; } }; };
                checkBtn.onclick = () => { const target = q.targetPhrase || "i love learning"; if(recordedText.includes(target) || target.includes(recordedText)){ resultDiv.innerHTML = `✅ Отлично! +10 очков`; resultDiv.style.background="#d4f5d4"; lesson.answers[qIdx]=true; prog.totalPoints+=10; saveCurrentProgress(); checkBtn.disabled=true; recordBtn.disabled=true; setTimeout(()=>goNext(),1000); } else { resultDiv.innerHTML = `❌ Попробуйте ещё раз. Нужно: "${target}"`; resultDiv.style.background="#ffe0db"; } updateStats(); };
            } else { resultDiv.innerHTML = "⚠️ Ваш браузер не поддерживает голосовой ввод"; checkBtn.style.display="inline-block"; checkBtn.onclick = () => { lesson.answers[qIdx]=true; prog.totalPoints+=5; saveCurrentProgress(); goNext(); updateStats(); }; }
        } else {
            let optsHtml = `<div class="options">`;
            q.options.forEach(opt => optsHtml += `<button class="option-btn" data-opt="${opt.replace(/"/g, '&quot;')}">${opt}</button>`);
            optsHtml += `</div><div id="fbArea" class="feedback"></div><button class="next-btn" id="nextQBtn" style="display:none;">Следующий →</button>`;
            document.getElementById("dynamicContent").innerHTML = `<div class="question-card"><div class="question-text">${q.question}</div>${optsHtml}</div>`;
            const btns = document.querySelectorAll(".option-btn");
            btns.forEach(btn => { btn.onclick = () => { const selected = btn.dataset.opt; const isCorrect = (selected === q.correct); const fb = document.getElementById("fbArea");
                if(isCorrect){ fb.innerHTML = `✅ Верно! +10 очков. ${q.explanation}`; fb.style.background="#d4f5d4"; lesson.answers[qIdx]=true; prog.totalPoints+=10; saveCurrentProgress(); document.getElementById("nextQBtn").style.display="inline-block"; btns.forEach(b=>b.disabled=true); }
                else { fb.innerHTML = `❌ Неверно. Правильно: ${q.correct}. ${q.explanation}`; fb.style.background="#ffe0db"; btns.forEach(b=>b.disabled=true); const retry = document.createElement("button"); retry.innerText="🔄 Попробовать снова"; retry.style.marginTop="0.5rem"; retry.style.padding="0.3rem 0.8rem"; retry.style.borderRadius="2rem"; retry.style.border="none"; retry.style.cursor="pointer"; retry.onclick = () => renderCurrentLesson(); fb.appendChild(retry); }
                updateStats(); }; });
            document.getElementById("nextQBtn")?.addEventListener("click", () => goNext());
        }
    }

    function goNext() {
        if(!currentUser || !currentUser.activeLanguage) return;
        const prog = currentUser.progress[currentUser.activeLanguage];
        const lesson = prog.lessonProgress[prog.currentLevel];
        if(lesson.qIdx + 1 < 5){ lesson.qIdx++; saveCurrentProgress(); renderCurrentLesson(); }
        else { if(lesson.answers.every(v=>v===true)){ if(!prog.completedLevels.includes(prog.currentLevel)){ prog.completedLevels.push(prog.currentLevel); prog.totalPoints+=50; } renderCurrentLesson(); } else alert("Ответьте правильно на все вопросы!"); }
        renderLevelList(); updateStats(); saveCurrentProgress();
    }

    function showAlphabet() {
        if(!currentUser || !currentUser.activeLanguage) return;
        const alphabet = fullAlphabets[currentUser.activeLanguage] || fullAlphabets.english;
        document.getElementById("alphabetLangName").innerHTML = `${alphabet.name} алфавит`;
        const container = document.getElementById("alphabetContent");
        container.innerHTML = "";
        for(let item of alphabet.letters) {
            const card = document.createElement("div");
            card.className = "alphabet-card";
            card.innerHTML = `<div class="alphabet-letter">${item.letter}</div><div class="alphabet-pron">📢 ${item.pronunciation}</div><div class="alphabet-example">✨ ${item.example}</div>`;
            container.appendChild(card);
        }
        document.getElementById("alphabetModal").style.display = "flex";
    }

    function changeLanguage(langCode, skillLevel) {
        if(!currentUser) return;
        if(!currentUser.progress[langCode]) initUserLevelsForLanguage(currentUser, langCode, skillLevel);
        else if(skillLevel && currentUser.progress[langCode].skillLevel !== skillLevel) { currentUser.progress[langCode].skillLevel = skillLevel; initUserLevelsForLanguage(currentUser, langCode, skillLevel); }
        currentUser.activeLanguage = langCode;
        saveCurrentProgress();
        const lang = languagesList.find(l=>l.code===langCode);
        document.getElementById("currentLangDisplay").innerHTML = `${lang.flag} ${lang.name}`;
        renderLevelList(); renderCurrentLesson(); updateStats();
    }

    function setupLanguageSelection() {
        const grid = document.getElementById("languageGrid");
        grid.innerHTML = "";
        languagesList.forEach(lang => {
            const div = document.createElement("div");
            div.className = "lang-option";
            div.innerHTML = `${lang.flag} ${lang.name}`;
            div.onclick = () => { document.querySelectorAll(".lang-option").forEach(l=>l.classList.remove("selected")); div.classList.add("selected"); window.selectedLangCode = lang.code; };
            grid.appendChild(div);
        });
        document.querySelectorAll(".lang-option")[0]?.classList.add("selected");
        window.selectedLangCode = 'english';
        document.querySelectorAll(".level-option").forEach(opt => opt.classList.remove("selected"));
        document.querySelector(".level-option")?.classList.add("selected");
        window.selectedSkill = 'beginner';
        document.querySelectorAll(".level-option").forEach(opt => { opt.onclick = () => { document.querySelectorAll(".level-option").forEach(o=>o.classList.remove("selected")); opt.classList.add("selected"); window.selectedSkill = opt.dataset.level; }; });
    }

    function login(username, password) {
        if(usersDB[username] && usersDB[username].password === password) {
            currentUser = usersDB[username];
            if(!currentUser.progress) currentUser.progress = {};
            if(!currentUser.activeLanguage) currentUser.activeLanguage = 'english';
            if(!currentUser.progress[currentUser.activeLanguage]) initUserLevelsForLanguage(currentUser, currentUser.activeLanguage, 'beginner');
            saveCurrentProgress();
            document.getElementById("authModal").style.display = "none";
            document.getElementById("userNameDisplay").innerText = username;
            setupLanguageSelection();
            document.getElementById("onboardingOverlay").style.display = "flex";
            return true;
        }
        document.getElementById("authError").innerText = "Неверное имя или пароль";
        return false;
    }

    function register(username, password) {
        if(usersDB[username]) { document.getElementById("authError").innerText = "Пользователь уже существует"; return false; }
        usersDB[username] = { username, password, progress: {}, activeLanguage: 'english' };
        saveUsersDB();
        return login(username, password);
    }

    document.getElementById("confirmLanguageBtn").onclick = () => { if(window.selectedLangCode && window.selectedSkill) { changeLanguage(window.selectedLangCode, window.selectedSkill); document.getElementById("onboardingOverlay").style.display = "none"; document.getElementById("mainInterface").style.display = "block"; renderLevelList(); renderCurrentLesson(); updateStats(); } };
    document.getElementById("alphabetButton")?.addEventListener("click", showAlphabet);
    document.getElementById("closeAlphabetBtn")?.addEventListener("click", () => document.getElementById("alphabetModal").style.display = "none");
    document.getElementById("resetProgressBtn")?.addEventListener("click",()=>{ if(confirm("Сбросить прогресс?")){ if(currentUser && currentUser.activeLanguage){ const lang=currentUser.activeLanguage, skill=currentUser.progress[lang].skillLevel; initUserLevelsForLanguage(currentUser, lang, skill); saveCurrentProgress(); renderLevelList(); renderCurrentLesson(); updateStats(); } } });
    document.getElementById("changeLanguageBtn")?.addEventListener("click",()=>{ document.getElementById("onboardingOverlay").style.display="flex"; setupLanguageSelection(); });
    document.getElementById("logoutMainBtn")?.addEventListener("click",()=>{ currentUser=null; document.getElementById("mainInterface").style.display="none"; document.getElementById("authModal").style.display="flex"; document.getElementById("authUsername").value=""; document.getElementById("authPassword").value=""; });
    document.getElementById("loginBtn")?.addEventListener("click",()=>{ const u=document.getElementById("authUsername").value.trim(), p=document.getElementById("authPassword").value; if(u&&p) login(u,p); });
    document.getElementById("registerBtn")?.addEventListener("click",()=>{ const u=document.getElementById("authUsername").value.trim(), p=document.getElementById("authPassword").value; if(u&&p) register(u,p); });

    loadUsersDB();
</script>
</body>
</html>
